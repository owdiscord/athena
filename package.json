{
  "name": "athena",
  "version": "0.0.1",
  "description": "",
  "private": true,
  "scripts": {
    "format": "oxfmt --write \"./backend/src/**/*.{css,html,js,json,ts,tsx}\" \"./dashboard/src/**/*.{css,html,js,json,ts,tsx}\"",
    "lint": "oxlint \"./backend/src/**/*.{js,ts,tsx}\" \"./dashboard/src/**/*.{js,ts,tsx}\"",
    "codestyle-check": "oxfmt --check \"./backend/src/**/*.{css,html,js,json,ts,tsx}\" \"./dashboard/src/**/*.{css,html,js,json,ts,tsx}\"",
    "start-bot": "cd backend && pnpm run start-bot-prod",
    "start-api": "cd backend && pnpm run start-api-prod",
    "start-dashboard": "cd dashboard && node serve.js"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@types/node": "^22.15.18",
    "oxc-transform": "^0.114.0",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "ts-toolbelt": "^9.6.0",
    "tsc-watch": "^6.0.4",
    "typescript": "=5.9.3"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  },
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "backend",
    "shared",
    "dashboard"
  ],
  "overrides": {
    "discord.js": "14.23.2",
    "discord-api-types": "0.38.30"
  }
}
